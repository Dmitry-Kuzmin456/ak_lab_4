        </mxCell>
        <mxCell id="mir" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=16;" value="MIR decoder&#xa;src dst alu mem move" vertex="1">
