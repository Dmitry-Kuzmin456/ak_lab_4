        </mxCell>
        <mxCell id="ctrl_bus" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=14;" value="Control signals&#xa;src sel, dst we, alu op&#xa;mem op, ip/ar sel" vertex="1">
