<mxfile host="app.diagrams.net" agent="Codex">
  <diagram id="ak4-readable-cpu-v3-layout" name="AK4 CPU scheme layout v3">
    <mxGraphModel dx="1928" dy="1334" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
