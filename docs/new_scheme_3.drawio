          <mxGeometry height="40" width="580" x="560" y="20" as="geometry" />
        </mxCell>

        <!-- ====== Control / uPC / Microcode / MIR / Control signals ====== -->
        <mxCell id="control" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=16;" value="Control Unit&#xa;dispatch, branches, port I/O&#xa;superscalar issue: LD+MUL / LD+CMP" vertex="1">
          <mxGeometry height="100" width="270" x="600" y="85" as="geometry" />
        </mxCell>
