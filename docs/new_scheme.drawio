<mxfile host="app.diagrams.net" agent="Codex">
  <diagram id="ak4-cpu-bw" name="AK4 CPU scheme">
    <mxGraphModel dx="2200" dy="1400" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" parent="1" value="Microcoded Harvard CISC CPU" style="text;html=1;strokeColor=none;fillColor=none;fontSize=22;fontStyle=1;align=center;" vertex="1">
          <mxGeometry x="700" y="20" width="600" height="36" as="geometry" />
        </mxCell>

        <!-- ============ ROW 1: CONTROL UNIT (top) ============ -->
        <mxCell id="control" parent="1" value="Control Unit&#xa;(uPC + Microcode 256x24 + MIR)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=16;" vertex="1">
          <mxGeometry x="500" y="90" width="900" height="80" as="geometry" />
        </mxCell>

        <!-- ============ ROW 2: FETCH + DECODE REGS ============ -->
        <mxCell id="ip" parent="1" value="IP" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=16;" vertex="1">
          <mxGeometry x="80" y="430" width="100" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cmd_mem" parent="1" value="Command Memory&#xa;2^16 x 8" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=15;" vertex="1">
          <mxGeometry x="260" y="400" width="190" height="120" as="geometry" />
        </mxCell>
        <mxCell id="cr" parent="1" value="CR" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=16;" vertex="1">
          <mxGeometry x="540" y="310" width="100" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ar" parent="1" value="AR" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=16;" vertex="1">
          <mxGeometry x="540" y="430" width="100" height="60" as="geometry" />
        </mxCell>
        <mxCell id="dr" parent="1" value="DR" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=16;" vertex="1">
          <mxGeometry x="540" y="550" width="100" height="60" as="geometry" />
        </mxCell>

        <!-- ============ SRC MUX + ALU + BR ============ -->
        <mxCell id="src_mux" parent="1" value="SRC MUX&#xa;IP/AR/DR/AC/IN" style="shape=trapezoid;direction=east;perimeter=trapezoidPerimeter;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=14;" vertex="1">
          <mxGeometry x="780" y="410" width="140" height="160" as="geometry" />
        </mxCell>
        <mxCell id="alu" parent="1" value="ALU&#xa;ADD SUB MUL DIV MOD&#xa;INC DEC PASS" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=15;" vertex="1">
          <mxGeometry x="1040" y="420" width="240" height="140" as="geometry" />
        </mxCell>
        <mxCell id="br" parent="1" value="BR&#xa;right operand" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=15;" vertex="1">
          <mxGeometry x="1400" y="455" width="140" height="70" as="geometry" />
        </mxCell>

        <!-- ============ AC, PS на правом фланге ============ -->
        <mxCell id="ac" parent="1" value="AC&#xa;accumulator" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=15;" vertex="1">
          <mxGeometry x="1700" y="455" width="140" height="70" as="geometry" />
        </mxCell>
        <mxCell id="ps" parent="1" value="PS&#xa;N Z V C" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=15;" vertex="1">
          <mxGeometry x="1700" y="310" width="140" height="60" as="geometry" />
        </mxCell>

        <!-- ============ WRITEBACK BUS (one long horizontal line) ============ -->
        <mxCell id="wb" parent="1" value="Writeback bus  (ALU result -&gt; AC · IP · AR · DR · BR · PS)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=14;" vertex="1">
          <mxGeometry x="80" y="720" width="1760" height="40" as="geometry" />
        </mxCell>

        <!-- ============ ROW 5: MEMORY + PORTS ============ -->
        <mxCell id="data_mem" parent="1" value="Data Memory&#xa;2^16 x 32" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=15;" vertex="1">
          <mxGeometry x="260" y="880" width="200" height="100" as="geometry" />
        </mxCell>
        <mxCell id="port_in" parent="1" value="Port IN" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;rounded=0;fillColor=none;strokeColor=#000000;fontSize=15;" vertex="1">
          <mxGeometry x="800" y="895" width="140" height="70" as="geometry" />
        </mxCell>
        <mxCell id="port_out" parent="1" value="Ports OUT" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;rounded=0;fillColor=none;strokeColor=#000000;fontSize=15;" vertex="1">
          <mxGeometry x="1680" y="895" width="160" height="70" as="geometry" />
        </mxCell>

        <!-- ============================================ -->
        <!-- ======= CONTROL → CR/AR/DR/MUX/ALU ========= -->
        <!-- Все пунктиры идут вертикально вниз из low edge ControlUnit. -->
        <!-- ============================================ -->
        <mxCell id="e_ctl_cr" edge="1" parent="1" source="control" target="cr" style="endArrow=classic;html=1;rounded=0;dashed=1;exitX=0.1;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;" value="dst_we">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_ctl_ar" edge="1" parent="1" source="control" target="ar" style="endArrow=classic;html=1;rounded=0;dashed=1;exitX=0.12;exitY=1;entryX=0.5;entryY=0;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="608" y="200" />
              <mxPoint x="608" y="410" />
              <mxPoint x="590" y="410" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_ctl_dr" edge="1" parent="1" source="control" target="dr" style="endArrow=classic;html=1;rounded=0;dashed=1;exitX=0.14;exitY=1;entryX=0.5;entryY=0;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="626" y="200" />
              <mxPoint x="626" y="540" />
              <mxPoint x="590" y="540" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_ctl_mux" edge="1" parent="1" source="control" target="src_mux" style="endArrow=classic;html=1;rounded=0;dashed=1;exitX=0.35;exitY=1;entryX=0.5;entryY=0;" value="src_sel">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_ctl_alu" edge="1" parent="1" source="control" target="alu" style="endArrow=classic;html=1;rounded=0;dashed=1;exitX=0.65;exitY=1;entryX=0.5;entryY=0;" value="alu_op">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_ctl_cmd" edge="1" parent="1" source="control" target="cmd_mem" style="endArrow=classic;html=1;rounded=0;dashed=1;exitX=0;exitY=0.5;entryX=0.5;entryY=0;" value="READ_CMD">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="355" y="130" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_ctl_mem" edge="1" parent="1" source="control" target="data_mem" style="endArrow=classic;html=1;rounded=0;dashed=1;exitX=0;exitY=0.7;entryX=0.5;entryY=0;" value="mem_op">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="40" y="146" />
              <mxPoint x="40" y="850" />
              <mxPoint x="360" y="850" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_ctl_io" edge="1" parent="1" source="control" target="port_out" style="endArrow=classic;html=1;rounded=0;dashed=1;exitX=1;exitY=0.5;entryX=0.5;entryY=0;" value="io_op">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1940" y="130" />
              <mxPoint x="1940" y="850" />
              <mxPoint x="1760" y="850" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ============ Feedback to Control: CR, PS ============ -->
        <mxCell id="e_cr_ctl" edge="1" parent="1" source="cr" target="control" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;entryX=0.2;entryY=1;" value="opcode">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="680" y="340" />
              <mxPoint x="680" y="260" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_ps_ctl" edge="1" parent="1" source="ps" target="control" style="endArrow=classic;html=1;rounded=0;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" value="NZVC">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============ Fetch path (left part, clean horizontal) ============ -->
        <mxCell id="e_ip_cmd" edge="1" parent="1" source="ip" target="cmd_mem" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" value="addr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_cmd_cr" edge="1" parent="1" source="cmd_mem" target="cr" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.15;entryX=0;entryY=0.5;" value="opcode">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_cmd_ar" edge="1" parent="1" source="cmd_mem" target="ar" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" value="addr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_cmd_dr" edge="1" parent="1" source="cmd_mem" target="dr" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.85;entryX=0;entryY=0.5;" value="imm8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============ Sources into SRC MUX ============ -->
        <!-- AR → MUX: прямой короткий, между блоками -->
        <mxCell id="e_ar_mux" edge="1" parent="1" source="ar" target="src_mux" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;entryX=0.05;entryY=0.3;" value="AR">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- DR → MUX: прямой короткий -->
        <mxCell id="e_dr_mux" edge="1" parent="1" source="dr" target="src_mux" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;entryX=0.05;entryY=0.7;" value="DR">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- IP → MUX: по нижнему коридору y=640 -->
        <mxCell id="e_ip_mux" edge="1" parent="1" source="ip" target="src_mux" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=1;entryX=0.1;entryY=1;" value="IP">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="130" y="670" />
              <mxPoint x="794" y="670" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- AC → MUX: по верхнему коридору y=270 → вниз слева от MUX -->
        <mxCell id="e_ac_mux" edge="1" parent="1" source="ac" target="src_mux" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=0;entryX=0.1;entryY=0;" value="AC">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1770" y="270" />
              <mxPoint x="794" y="270" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- IN → MUX -->
        <mxCell id="e_in_mux" edge="1" parent="1" source="port_in" target="src_mux" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=0;entryX=0.5;entryY=1;" value="IN">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="870" y="800" />
              <mxPoint x="850" y="800" />
              <mxPoint x="850" y="600" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ============ ALU inputs (exactly 2) ============ -->
        <mxCell id="e_mux_alu" edge="1" parent="1" source="src_mux" target="alu" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" value="left">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_br_alu" edge="1" parent="1" source="br" target="alu" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" value="right">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============ ALU outputs ============ -->
        <mxCell id="e_alu_ps" edge="1" parent="1" source="alu" target="ps" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.15;entryX=0;entryY=0.5;" value="flags">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1660" y="441" />
              <mxPoint x="1660" y="340" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_alu_wb" edge="1" parent="1" source="alu" target="wb" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.65;entryY=0;" value="result">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============ Writeback fan-out ============ -->
        <mxCell id="e_wb_ac" edge="1" parent="1" source="wb" target="ac" style="endArrow=classic;html=1;rounded=0;exitX=0.92;exitY=0;entryX=0.5;entryY=1;" value="AC">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_wb_br" edge="1" parent="1" source="wb" target="br" style="endArrow=classic;html=1;rounded=0;exitX=0.78;exitY=0;entryX=0.5;entryY=1;" value="BR">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_wb_ps" edge="1" parent="1" source="wb" target="ps" style="endArrow=classic;html=1;rounded=0;exitX=0.99;exitY=0;entryX=0.5;entryY=1;" value="PS">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1822" y="395" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_wb_dr" edge="1" parent="1" source="wb" target="dr" style="endArrow=classic;html=1;rounded=0;exitX=0.295;exitY=0;entryX=0.6;entryY=1;" value="DR">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_wb_ar" edge="1" parent="1" source="wb" target="ar" style="endArrow=classic;html=1;rounded=0;exitX=0.265;exitY=0;entryX=0.85;entryY=1;" value="AR">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="546" y="700" />
              <mxPoint x="625" y="700" />
              <mxPoint x="625" y="500" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_wb_ip" edge="1" parent="1" source="wb" target="ip" style="endArrow=classic;html=1;rounded=0;exitX=0;exitY=0.5;entryX=0.5;entryY=1;" value="IP">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="50" y="740" />
              <mxPoint x="50" y="510" />
              <mxPoint x="130" y="510" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ============ Data Memory <-> AR (addr), DR (read/write) ============ -->
        <!-- AR → DataMem: вниз через коридор x=470 -->
        <mxCell id="e_ar_dmem" edge="1" parent="1" source="ar" target="data_mem" style="endArrow=classic;html=1;rounded=0;exitX=0;exitY=1;entryX=0.9;entryY=0;" value="addr">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="510" y="790" />
              <mxPoint x="440" y="790" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- DR ↔ DataMem: вниз через коридор x=490 -->
        <mxCell id="e_dr_dmem" edge="1" parent="1" source="dr" target="data_mem" style="endArrow=classic;html=1;rounded=0;exitX=0;exitY=1;entryX=0.5;entryY=0;" value="write">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="490" y="800" />
              <mxPoint x="360" y="800" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_dmem_dr" edge="1" parent="1" source="data_mem" target="dr" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;entryX=1;entryY=1;" value="read">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="690" y="930" />
              <mxPoint x="690" y="615" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ============ Ports OUT ============ -->
        <!-- AC → PortsOUT: правый край -->
        <mxCell id="e_ac_out" edge="1" parent="1" source="ac" target="port_out" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;entryX=1;entryY=0;" value="OUT">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1900" y="490" />
              <mxPoint x="1900" y="850" />
              <mxPoint x="1820" y="850" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- DR → PortsOUT (OUT_CSTR): коридор y=830 -->
        <mxCell id="e_dr_out" edge="1" parent="1" source="dr" target="port_out" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=1;entryX=0;entryY=0.5;" value="OUT_CSTR">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="670" y="640" />
              <mxPoint x="990" y="640" />
              <mxPoint x="990" y="830" />
              <mxPoint x="1680" y="830" />
              <mxPoint x="1680" y="930" />
            </Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
